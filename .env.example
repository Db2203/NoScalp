# Copy to .env.local and fill in.

# Secret used to HMAC contact info into identity hashes. Use a long random string.
# Required in production (the app refuses to start with the default there).
NOSCALP_IDENTITY_SECRET=change-me-to-something-random

# Optional: seed for the provably-fair draw commitment. Falls back to
# NOSCALP_IDENTITY_SECRET if unset. Set a distinct long random value in prod.
# NOSCALP_SEED_SECRET=another-long-random-string

# Optional: protect the admin/demo endpoints (draw, flood, reset, populate,
# naive, consistency) on a public deployment. If set, callers must send it as the
# `x-admin-token` header (the /fairness page has a field for it). Set this on any
# public deploy — it prevents anonymous writes (and runaway DSQL cost).
# NOSCALP_ADMIN_TOKEN=another-long-random-token

# Optional: Stripe test-mode checkout (winners pay on claim). Without these, the
# claim finalizes directly (no payment step). Use TEST keys from
# Stripe Dashboard → Developers → API keys.
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─────────────────────────────────────────────────────────────
# Option A — Local Postgres (no AWS needed; both "regions" share it)
# ─────────────────────────────────────────────────────────────
# NOSCALP_DB_MODE=local
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/noscalp

# ─────────────────────────────────────────────────────────────
# Option B — Amazon Aurora DSQL (the real thing)
# ─────────────────────────────────────────────────────────────
# NOSCALP_DB_MODE=dsql
# DSQL_ENDPOINT_A=<cluster-id>.dsql.us-east-1.on.aws
# DSQL_ENDPOINT_B=<cluster-id>.dsql.us-east-2.on.aws   # multi-region peer (optional; falls back to A)
# DSQL_REGION_A=us-east-1
# DSQL_REGION_B=us-east-2
# DSQL_USER=admin
# DSQL_DATABASE=postgres
#
# AWS credentials come from the standard provider chain:
#   - locally: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION
#   - on Vercel: OIDC federation to an IAM role (see SETUP.md)
